# Copy this file to backend/.env for local backend development.
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:5173
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/velocity_gp
# Optional direct URL overrides for adapter-based seeding/runtime.
# Use these when DATABASE_URL is prisma+postgres:// (Prisma Accelerate).
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/velocity_gp
SEED_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/velocity_gp
AUTH_SECRET=replace-me
MAGIC_LINK_TOKEN_TTL_MINUTES=15
AUTH_SESSION_TTL_HOURS=72
# n8n email flow webhook — pipes outbound transactional emails through Mailtrap.
# Set N8N_HOST to the n8n host URL (e.g. https://n8n.example.com).
# N8N_WEBHOOK_TOKEN is used as the HS512 JWT signing secret for outbound n8n calls.
N8N_HOST=
N8N_WEBHOOK_TOKEN=
N8N_WEBHOOK_TIMEOUT_MS=5000
