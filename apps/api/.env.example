# Copy this file to backend/.env for local backend development.
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:5173
# Callback domain embedded in outbound magic-link emails.
# For remote/dev deployments set this to your deployed web URL.
FRONTEND_MAGIC_LINK_ORIGIN=https://dev.velocitygp.app
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/velocity_gp
# Optional direct URL overrides for adapter-based seeding/runtime.
# Use these when DATABASE_URL is prisma+postgres:// (Prisma Accelerate).
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/velocity_gp
SEED_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/velocity_gp
AUTH_SECRET=replace-me
MAGIC_LINK_TOKEN_TTL_MINUTES=15
AUTH_SESSION_TTL_HOURS=72
# n8n webhook integration:
# - /sendmail for outbound transactional emails through Mailtrap
# - N8N_QRCODEGEN_WEBHOOK_PATH_TEMPLATE controls QR generation path (use {env} placeholder)
# Set N8N_HOST to the n8n host URL (e.g. https://n8n.example.com).
# N8N_WEBHOOK_TOKEN is used as the HS512 JWT signing secret for outbound n8n calls.
# MAILTRAP_WEBHOOK_SECRET is used to verify inbound Mailtrap webhook signatures.
N8N_HOST=
N8N_QRCODEGEN_WEBHOOK_PATH_TEMPLATE=/webhook/{env}/QRCodeGen
N8N_WEBHOOK_TOKEN=
MAILTRAP_WEBHOOK_SECRET=
N8N_WEBHOOK_TIMEOUT_MS=5000

# Garage workflow — team logo generation via n8n + OpenAI moderation
# N8N_IMAGE_API_URL: n8n webhook endpoint that generates team logos.
# When absent, logo generation is skipped and a dev placeholder is returned.
N8N_IMAGE_API_URL=
# N8N_IMAGE_API_KEY: shared secret used to sign JWT tokens sent to the n8n image webhook (HS512).
N8N_IMAGE_API_KEY=
# OPENAI_API_KEY: used by moderationService for the OpenAI Moderations endpoint.
# When absent, falls back to a keyword blocklist (dev only — not safe for production).
OPENAI_API_KEY=
# STORAGE_BASE_URL: base URL for the storage bucket used to build public image URLs
# from the imageFileName returned by n8n (e.g. https://velocity-app.nyc3.digitaloceanspaces.com).
STORAGE_BASE_URL=
# GARAGE_REQUIRED_PLAYER_COUNT: number of approved descriptions required before logo generation fires.
# Defaults to 2 (real team size). Set to 1 in dev to trigger from a single submission.
GARAGE_REQUIRED_PLAYER_COUNT=2
