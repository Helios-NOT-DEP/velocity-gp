{
  "name": "@velocity-gp/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prebuild": "npm run build --workspace=@velocity-gp/api-contract && npm run db:generate",
    "build:app": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src tests --ext .ts --config ../../eslint.config.js",
    "lint:fix": "eslint src tests --ext .ts --config ../../eslint.config.js --fix",
    "pretest": "npm run db:generate && npm run db:deploy",
    "pretest:integration": "npm run db:generate && npm run db:deploy",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts apps/api/tests/unit",
    "test:integration": "vitest run --config vitest.config.ts apps/api/tests/integration",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy --config ../../prisma.config.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "auth:magic-link": "tsx scripts/generateLocalMagicLink.ts"
  },
  "dependencies": {
    "@opentelemetry/winston-transport": "^0.24.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@velocity-gp/api-contract": "0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "pg": "^8.20.0",
    "pino": "^10.1.0",
    "vite": "6.4.2",
    "winston": "^3.19.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^25.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@velocity-gp/config-typescript": "0.1.0",
    "prisma": "^7.6.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "vite": {
    "api": {
      "base": "http://localhost:4000/api"
    }
  }
}
