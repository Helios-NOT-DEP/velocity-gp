generator client {
    provider = "prisma-client"
    output   = "./generated"
}

datasource db {
    provider = "postgresql"
}

enum UserRole {
    ADMIN
    HELIOS
    PLAYER
}

enum EventStatus {
    UPCOMING
    ACTIVE
    COMPLETED
}

enum TeamStatus {
    PENDING
    ACTIVE
    IN_PIT
}

enum PlayerStatus {
    RACING
    IN_PIT
    FINISHED
}

enum RaceControlState {
    ACTIVE
    PAUSED
}

enum QRCodeStatus {
    ACTIVE
    DISABLED
}

enum ScanOutcome {
    SAFE
    HAZARD_PIT
    INVALID
    DUPLICATE
    BLOCKED
}

enum RescueStatus {
    REQUESTED
    IN_PROGRESS
    COMPLETED
    REJECTED
}

enum TeamActivityType {
    PLAYER_ONBOARDING_COMPLETED
    PLAYER_QR_SCAN
}

enum TeamTransitionReason {
    HAZARD_TRIGGER
    RESCUE_CLEARED
    TIMER_EXPIRED
    ADMIN_MANUAL
    SYSTEM_RESET
}

enum AdminActionType {
    RACE_PAUSED
    RACE_RESUMED
    HELIOS_ASSIGNED
    HELIOS_REVOKED
    PIT_MANUAL_ENTER
    PIT_MANUAL_CLEAR
    QR_CREATED
    QR_STATUS_UPDATED
    QR_DELETED
    QR_HAZARD_RANDOMIZER_UPDATED
    SCORE_RESET
    ROSTER_IMPORTED
    ROSTER_ASSIGNED
    ROSTER_REASSIGNED
    ROSTER_UNASSIGNED
    EMAIL_RETURN_FLAGGED
    EVENT_HAZARD_SETTINGS_UPDATED
    QR_IMPORT_APPLIED
    HAZARD_MULTIPLIER_CREATED
    HAZARD_MULTIPLIER_UPDATED
    HAZARD_MULTIPLIER_DELETED
    USER_CAPABILITIES_UPDATED
    TEAM_SCORE_UPDATED
    TEAM_SOFT_DELETED
    PLAYER_CONTACT_UPDATED
    PLAYER_REVIEW_FLAG_RESOLVED
}

enum EmailProvider {
    MAILTRAP
}

model User {
    id                  String   @id @default(cuid())
    email               String   @unique
    displayName         String
    phoneE164           String?
    role                UserRole @default(PLAYER)
    canAdmin            Boolean  @default(false)
    canPlayer           Boolean  @default(true)
    isHeliosMember      Boolean  @default(false)
    isHelios            Boolean  @default(false)
    hasReturnEmailIssue Boolean  @default(false)
    createdAt           DateTime @default(now())
    updatedAt           DateTime @updatedAt

    players           Player[]
    adminActionAudits AdminActionAudit[]    @relation("AdminActionActor")
    rescuesGiven      Rescue[]              @relation("RescueScannedBy")
    teamTransitions   TeamStateTransition[] @relation("TeamTransitionTriggeredByUser")
    emailEvents       EmailEvent[]
}

model Event {
    id                 String      @id @default(cuid())
    name               String
    description        String?
    startDate          DateTime
    endDate            DateTime
    status             EventStatus @default(UPCOMING)
    maxPlayers         Int?
    currentPlayerCount Int         @default(0)
    venueId            String?
    isPublic           Boolean     @default(true)
    createdAt          DateTime    @default(now())
    updatedAt          DateTime    @updatedAt

    config            EventConfig?
    teams             Team[]
    players           Player[]
    qrCodes           QRCode[]
    qrCodeClaims      QRCodeClaim[]
    scanRecords       ScanRecord[]
    teamActivityEvents TeamActivityEvent[]
    rescues           Rescue[]
    teamTransitions   TeamStateTransition[]
    adminActionAudits AdminActionAudit[]
    emailEvents       EmailEvent[]
    hazardMultiplierRules HazardMultiplierRule[]
}

model EventConfig {
    id                     String           @id @default(cuid())
    eventId                String           @unique
    globalHazardRatio      Int              @default(15)
    pitStopDurationSeconds Int              @default(900)
    invalidScanPenalty     Int              @default(1)
    raceControlState       RaceControlState @default(ACTIVE)
    createdAt              DateTime         @default(now())
    updatedAt              DateTime         @updatedAt

    event Event @relation(fields: [eventId], references: [id])
}

model HazardMultiplierRule {
    id              String   @id @default(cuid())
    eventId         String
    name            String
    startsAt        DateTime
    endsAt          DateTime
    ratioMultiplier Float
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt
    deletedAt       DateTime?

    event Event @relation(fields: [eventId], references: [id])

    @@index([eventId, startsAt])
    @@index([eventId, endsAt])
    @@index([eventId, deletedAt])
}

model Team {
    id               String     @id @default(cuid())
    name             String
    eventId          String
    score            Int        @default(0)
    status           TeamStatus @default(PENDING)
    pitStopExpiresAt DateTime?
    deletedAt        DateTime?
    createdAt        DateTime   @default(now())
    updatedAt        DateTime   @updatedAt

    event            Event                 @relation(fields: [eventId], references: [id])
    players          Player[]
    scanRecords      ScanRecord[]
    teamActivityEvents TeamActivityEvent[]
    rescuesRequested Rescue[]              @relation("RescueRequestingTeam")
    teamTransitions  TeamStateTransition[]

    @@unique([eventId, name])
    @@index([eventId])
    @@index([eventId, status])
    @@index([eventId, deletedAt])
}

model Player {
    id                  String       @id @default(cuid())
    userId              String
    eventId             String
    teamId              String?
    status              PlayerStatus @default(RACING)
    individualScore     Int          @default(0)
    isFlaggedForReview  Boolean      @default(false)
    hasReturnEmailIssue Boolean      @default(false)
    joinedAt            DateTime     @default(now())
    createdAt           DateTime     @default(now())
    updatedAt           DateTime     @updatedAt

    user             User                  @relation(fields: [userId], references: [id])
    event            Event                 @relation(fields: [eventId], references: [id])
    team             Team?                 @relation(fields: [teamId], references: [id])
    qrClaims         QRCodeClaim[]
    scanRecords      ScanRecord[]
    teamActivityEvents TeamActivityEvent[]
    rescuesRequested Rescue[]              @relation("RescueRequestingPlayer")
    teamTransitions  TeamStateTransition[] @relation("TeamTransitionTriggeredByPlayer")
    emailEvents      EmailEvent[]

    @@unique([eventId, userId])
    @@index([eventId])
    @@index([teamId])
}

model QRCode {
    id                   String       @id @default(cuid())
    eventId              String
    label                String
    value                Int
    zone                 String?
    payload              String       @unique
    qrImageUrl           String?
    status               QRCodeStatus @default(ACTIVE)
    activationStartsAt   DateTime?
    activationEndsAt     DateTime?
    hazardRatioOverride  Int?
    hazardWeightOverride Int?
    scanCount            Int          @default(0)
    createdAt            DateTime     @default(now())
    updatedAt            DateTime     @updatedAt
    deletedAt            DateTime?

    event       Event         @relation(fields: [eventId], references: [id])
    claims      QRCodeClaim[]
    scanRecords ScanRecord[]
    teamActivityEvents TeamActivityEvent[]

    @@unique([eventId, label])
    @@index([eventId])
    @@index([eventId, status])
    @@index([eventId, deletedAt])
}

model QRCodeClaim {
    id        String   @id @default(cuid())
    eventId   String
    qrCodeId  String
    playerId  String
    claimedAt DateTime @default(now())

    event  Event  @relation(fields: [eventId], references: [id])
    qrCode QRCode @relation(fields: [qrCodeId], references: [id])
    player Player @relation(fields: [playerId], references: [id])

    @@unique([qrCodeId, playerId])
    @@index([eventId, playerId])
}

model ScanRecord {
    id                    String      @id @default(cuid())
    eventId               String
    qrCodeId              String?
    playerId              String
    teamId                String?
    outcome               ScanOutcome
    pointsAwarded         Int         @default(0)
    hazardRatioUsed       Int?
    globalScanCountBefore Int?
    globalScanCountAfter  Int?
    scannedPayload        String
    message               String?
    createdAt             DateTime    @default(now())

    event  Event   @relation(fields: [eventId], references: [id])
    qrCode QRCode? @relation(fields: [qrCodeId], references: [id])
    player Player  @relation(fields: [playerId], references: [id])
    team   Team?   @relation(fields: [teamId], references: [id])

    @@index([eventId, createdAt])
    @@index([playerId, createdAt])
    @@index([outcome])
}

model TeamStateTransition {
    id                  String               @id @default(cuid())
    eventId             String
    teamId              String
    fromStatus          TeamStatus?
    toStatus            TeamStatus
    reason              TeamTransitionReason
    triggeredByUserId   String?
    triggeredByPlayerId String?
    notes               String?
    createdAt           DateTime             @default(now())

    event             Event   @relation(fields: [eventId], references: [id])
    team              Team    @relation(fields: [teamId], references: [id])
    triggeredByUser   User?   @relation("TeamTransitionTriggeredByUser", fields: [triggeredByUserId], references: [id])
    triggeredByPlayer Player? @relation("TeamTransitionTriggeredByPlayer", fields: [triggeredByPlayerId], references: [id])

    @@index([eventId, createdAt])
    @@index([teamId, createdAt])
}

model AdminActionAudit {
    id          String          @id @default(cuid())
    eventId     String
    actorUserId String
    actionType  AdminActionType
    targetType  String
    targetId    String?
    details     Json?
    createdAt   DateTime        @default(now())

    event     Event @relation(fields: [eventId], references: [id])
    actorUser User  @relation("AdminActionActor", fields: [actorUserId], references: [id])

    @@index([eventId, createdAt])
    @@index([actorUserId, createdAt])
}

model EmailEvent {
    id                       String        @id @default(cuid())
    provider                 EmailProvider
    providerEventId          String?
    eventType                String
    occurredAt               DateTime
    recipientEmailRaw        String
    recipientEmailNormalized String
    messageId                String?
    sendingStream            String?
    inboxId                  String?
    isReturnSignal           Boolean       @default(false)
    payload                  Json
    eventId                  String?
    userId                   String?
    playerId                 String?
    createdAt                DateTime      @default(now())
    updatedAt                DateTime      @updatedAt

    event  Event?  @relation(fields: [eventId], references: [id])
    user   User?   @relation(fields: [userId], references: [id])
    player Player? @relation(fields: [playerId], references: [id])

    @@unique([provider, providerEventId])
    @@index([recipientEmailNormalized, occurredAt])
    @@index([isReturnSignal, occurredAt])
    @@index([eventType, occurredAt])
    @@index([eventId, createdAt])
    @@index([userId, createdAt])
    @@index([playerId, createdAt])
}

model Rescue {
    id                 String       @id @default(cuid())
    eventId            String
    requestingPlayerId String
    requestingTeamId   String
    rescuerUserId      String
    status             RescueStatus @default(REQUESTED)
    reason             String?
    initiatedAt        DateTime     @default(now())
    completedAt        DateTime?
    cooldownExpiresAt  DateTime?
    createdAt          DateTime     @default(now())
    updatedAt          DateTime     @updatedAt

    event            Event  @relation(fields: [eventId], references: [id])
    requestingPlayer Player @relation("RescueRequestingPlayer", fields: [requestingPlayerId], references: [id])
    requestingTeam   Team   @relation("RescueRequestingTeam", fields: [requestingTeamId], references: [id])
    rescuerUser      User   @relation("RescueScannedBy", fields: [rescuerUserId], references: [id])

    @@index([eventId, initiatedAt])
    @@index([requestingPlayerId])
    @@index([requestingTeamId])
}

model TeamActivityEvent {
    id           String           @id @default(cuid())
    eventId      String
    teamId       String
    playerId     String
    qrCodeId     String?
    type         TeamActivityType
    sourceKey    String
    scanOutcome  ScanOutcome?
    pointsAwarded Int?
    errorCode    String?
    qrCodeLabel  String?
    qrPayload    String?
    summary      String
    occurredAt   DateTime
    createdAt    DateTime         @default(now())

    event  Event   @relation(fields: [eventId], references: [id])
    team   Team    @relation(fields: [teamId], references: [id])
    player Player  @relation(fields: [playerId], references: [id])
    qrCode QRCode? @relation(fields: [qrCodeId], references: [id])

    @@unique([eventId, sourceKey])
    @@index([eventId, teamId, occurredAt])
    @@index([teamId, occurredAt])
    @@index([playerId, occurredAt])
}
