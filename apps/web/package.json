{
  "name": "@velocity-gp/web",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "lint": "eslint src tests --ext .ts,.tsx --config ../../eslint.config.js",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts apps/web/tests/unit",
    "test:component": "vitest run --config vitest.config.ts apps/web/tests/component",
    "test:e2e": "npm run build && playwright test --config playwright.config.ts",
    "format": "prettier --write src tests"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@velocity-gp/api-client": "0.1.0",
    "@velocity-gp/api-contract": "0.1.0",
    "@velocity-gp/ui": "0.1.0",
    "@yudiel/react-qr-scanner": "^2.5.1",
    "canvas-confetti": "1.9.4",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "posthog-js": "^1.364.5",
    "react": "18.3.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.3.1",
    "react-responsive-masonry": "2.7.1",
    "react-router": "7.13.0",
    "react-slick": "0.31.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/vite": "4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.3",
    "@velocity-gp/config-typescript": "0.1.0",
    "@vitejs/plugin-react": "4.7.0",
    "happy-dom": "^20.8.9",
    "qrcode-generator": "^2.0.4",
    "tailwindcss": "4.1.12",
    "typescript": "^6.0.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.2"
  }
}
