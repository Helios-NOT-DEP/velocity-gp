# Copy this file to .env.local and update values for your environment.
# Do not commit .env.local to version control.
# See DEVELOPMENT.md for additional setup instructions.

# API Configuration

# Backend API URL
VITE_API_BASE_URL=http://localhost:4000/api

# Current event context
VITE_EVENT_ID=event-123

# Optional: Development Features

# Enable debug mode for development
VITE_DEBUG=true

# API request timeout (milliseconds)
VITE_API_TIMEOUT=10000

# Enable mock data (for local testing without backend)
VITE_USE_MOCK_DATA=false

# Authentication (Future - When Auth.js is ready)

# Auth.js configuration
# #TODO(#12): Confirm final Auth.js callback and session cookie settings once magic-link auth is implemented.
VITE_AUTH_URL=http://localhost:4000
VITE_AUTH_CALLBACK_URL=http://localhost:5173/auth/callback

# Third-Party Services (Future - When Integrated)

# ElevenLabs for text-to-speech
VITE_ELEVENLABS_API_KEY=your_key_here

# #TODO(#12): Add SendGrid sender + API key variables used by Auth.js email provider.

# PostHog for analytics + database
# Use a direct Postgres URL for adapter-based Prisma runtime/seeding.
# If your app DATABASE_URL uses prisma+postgres:// (Prisma Accelerate),
# set DIRECT_DATABASE_URL (and optionally SEED_DATABASE_URL) to a direct postgres:// URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:16432/velocitygp?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:16432/velocitygp?schema=public"
SEED_DATABASE_URL="postgresql://postgres:postgres@localhost:16432/velocitygp?schema=public"
VITE_POSTHOG_KEY=your_key_here
VITE_POSTHOG_HOST=n.velocitygp.app

# Observability
VITE_OBSERVABILITY_DEBUG=false
VITE_OTEL_SERVICE_NAME=velocity-gp-web
VITE_OTEL_TRACE_SAMPLING_RATE=1
