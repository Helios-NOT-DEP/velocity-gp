# Copy this file to .env.local and update values for your environment.
# Do not commit .env.local to version control.
# See DEVELOPMENT.md for additional setup instructions.

# API Configuration

# Backend API URL
VITE_API_BASE_URL=http://localhost:4000/api

# Current event context
VITE_EVENT_ID=event-123

# Optional: Development Features

# Enable debug mode for development
VITE_DEBUG=true

# API request timeout (milliseconds)
VITE_API_TIMEOUT=10000

# Enable mock data (for local testing without backend)
VITE_USE_MOCK_DATA=false

# Authentication (Future - When Auth.js is ready)

# Auth.js configuration
VITE_AUTH_URL=http://localhost:4000
VITE_AUTH_CALLBACK_URL=http://localhost:5173/garage
AUTH_SECRET=replace_with_a_long_random_secret
AUTH_EMAIL_FROM=auth@yourdomain.com
AUTH_SENDGRID_API_KEY=SG.your_sendgrid_api_key
AUTH_MAGIC_LINK_MAX_AGE_SECONDS=900
AUTH_SESSION_MAX_AGE_SECONDS=604800
AUTH_SESSION_UPDATE_AGE_SECONDS=43200
AUTH_EVENT_ID=event-123

# Third-Party Services (Future - When Integrated)

# ElevenLabs for text-to-speech
VITE_ELEVENLABS_API_KEY=your_key_here

# PostHog for analytics
VITE_POSTHOG_KEY=your_key_here
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_API_KEY=your_project_api_key_here

# Observability
VITE_OBSERVABILITY_DEBUG=false
VITE_OTEL_SERVICE_NAME=velocity-gp-web
VITE_OTEL_TRACE_SAMPLING_RATE=1
