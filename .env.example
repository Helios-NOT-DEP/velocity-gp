# Copy this file to .env.local and update values for your environment.
# Do not commit .env.local to version control.
# See DEVELOPMENT.md for additional setup instructions.

# Runtime mode
NODE_ENV=development

# API server configuration
HOST=0.0.0.0
PORT=3000
API_PREFIX=/api
LOG_LEVEL=info

# Trusted frontend origins (comma-separated list for API CORS allowlist)
FRONTEND_ORIGIN=http://localhost:5173

# Domain used inside magic-link emails generated by the API service.
# In production this must be an HTTPS non-localhost origin.
FRONTEND_MAGIC_LINK_ORIGIN=http://localhost:5173

# Web app API configuration
VITE_API_BASE_URL=http://localhost:3000/api

# Client-side mirror of the trusted frontend origin used to validate QR redirects in Race Hub
VITE_FRONTEND_MAGIC_LINK_ORIGIN=https://localhost:3000

# Current event context
VITE_EVENT_ID=event-123

# Optional: development features

# Enable debug mode for development
VITE_DEBUG=true

# API request timeout (milliseconds)
VITE_API_TIMEOUT=10000

# Enable mock data (for local testing without backend)
VITE_USE_MOCK_DATA=false

# Authentication

# Frontend Auth.js placeholders (kept for upcoming auth integration)
# TODO(#12): Confirm final Auth.js callback and session cookie settings once magic-link auth is implemented.
VITE_AUTH_URL=http://localhost:3000
VITE_AUTH_CALLBACK_URL=http://localhost:5173/auth/callback

# API auth/session settings
AUTH_SECRET=replace-me
MAGIC_LINK_TOKEN_EXPIRY_DATE="2026-04-16T12:00:00-05:00"
MAGIC_LINK_TOKEN_TTL_MINUTES=15
AUTH_SESSION_TTL_HOURS=72
AUTH_SESSION_COOKIE_TTL_DAYS=5

# Third-party services

# ElevenLabs for text-to-speech
VITE_ELEVENLABS_API_KEY=your_key_here

# n8n flow — transactional emails route through n8n > Mailtrap (SendGrid removed).
# N8N_WEBHOOK_TOKEN and MAILTRAP_WEBHOOK_SECRET should be 16+ characters.
N8N_HOST=
N8N_WEBHOOK_TOKEN=
N8N_WEBHOOK_TIMEOUT_MS=5000

# Inbound Mailtrap webhook signature secret
MAILTRAP_WEBHOOK_SECRET=replace-with-mailtrap-webhook-secret
MAILTRAP_AUDIT_ACTOR_EMAIL=system+mailtrap@velocitygp.internal

# Optional pit release scheduler/webhook integration
PIT_RELEASE_SCHEDULER_ENABLED=true
PIT_RELEASE_POLL_INTERVAL_MS=10000
PIT_RELEASE_BATCH_SIZE=50
PIT_RELEASE_WEBHOOK_URL=
PIT_RELEASE_WEBHOOK_TIMEOUT_MS=3000

# Database (Prisma + Postgres)
# Use a direct Postgres URL for adapter-based Prisma runtime/seeding.
# If your app DATABASE_URL uses prisma+postgres:// (Prisma Accelerate),
# set DIRECT_DATABASE_URL (and optionally SEED_DATABASE_URL) to a direct postgres:// URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:16432/velocitygp?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:16432/velocitygp?schema=public"
SEED_DATABASE_URL="postgresql://postgres:postgres@localhost:16432/velocitygp?schema=public"


# PostHog + observability
# Either VITE_POSTHOG_KEY or VITE_POSTHOG_API_KEY can be used by the web app.
VITE_POSTHOG_KEY=your_key_here
VITE_POSTHOG_API_KEY=your_key_here
VITE_POSTHOG_HOST=n.velocitygp.app

# Server-side public PostHog passthrough envs consumed by API config
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=
SERVICE_NAME=velocity-gp-api

# Observability
VITE_OBSERVABILITY_DEBUG=false
VITE_OTEL_SERVICE_NAME=velocity-gp-web
VITE_OTEL_TRACE_SAMPLING_RATE=1

# Build/test toggles
# Set to true to emit web build sourcemaps.
SOURCEMAP=false
